ymmsl_version: v0.2

imports:
- from a.e import implementation test_model

models:
  test_macro_macro:
    description: Two macro models!
    components:
      macro1:
        ports:
          o_i: out
          s: in
        description: Macro model
        implementation: test_model
      macro2:
        ports:
          o_i: out
          s: in
        description: Macro model
        implementation: test_model

programs:
  macro2:
    ports:
      o_i: out
      s: in
    description: Alternative macro model implementation
    executable: python3
    args: /home/user/macro2.py

custom_implementations:
  test_macro_macro.macro2.macro: macro2

